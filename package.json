{
  "name": "lottery-bot",
  "version": "1.0.0",
  "description": "Discord lottery bot with ticket system",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "watch": "tsc --watch",
    "create-template": "ts-node src/createTemplate.ts",
    "analyze-ticket": "ts-node analyze_ticket_layout.ts",
    "test-ticket": "ts-node test_ticket.ts",
    "audit-lottery-data": "ts-node src/repairLotteryData.ts --guild 1052886751221383198",
    "fix-lottery-data": "ts-node src/repairLotteryData.ts --guild 1052886751221383198 --fix"
  },
  "keywords": [
    "discord",
    "bot",
    "lottery"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@napi-rs/canvas": "^0.1.99",
    "axios": "^1.7.9",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5",
    "mongoose": "^8.8.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
